{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": false,
    "permission": {
        "bash": {
            "*": "ask",
            "awk *": "allow",
            "cat *": "allow",
            "echo *": "allow",
            "git *": "allow",
            "git commit *": "ask",
            "grep *": "allow",
            "head *": "allow",
            "jq *": "allow",
            "ls *": "allow",
            "tail *": "allow",
            "tr *": "allow"
        },
        "edit": "ask"
    }
}
